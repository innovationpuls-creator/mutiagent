#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import shutil
import sys
import tempfile
import uuid
from pathlib import Path

DEPLOY_DIR = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(DEPLOY_DIR / "lib"))

from migration_manifest import (  # noqa: E402
    assert_manifest_repository_revision,
    begin_directory_replacement,
    blocked_termination_signals,
    extract_upload_archive,
    extract_verified_bundle,
    inspect_database_identity,
    migrate_database_to_head,
    postgres_service_environment,
    replace_database_name,
    repository_revision_sets,
    run_process_group,
    termination_signal_guard,
    validate_replacement_target,
)

REQUIRED_ACCOUNTS = (
    ("13297540721", "admin"),
    ("18771701100", "student"),
    ("18771701111", "admin"),
)


def _query(
    database_environment: dict[str, str], service_name: str, sql: str
) -> list[str]:
    result = run_process_group(
        [
            "psql",
            "--no-psqlrc",
            f"--dbname=service={service_name}",
            "--tuples-only",
            "--no-align",
            "--command",
            sql,
        ],
        check=True,
        capture_output=True,
        text=True,
        env=database_environment,
    )
    return [line for line in result.stdout.splitlines() if line]


def _restore_dump(
    dump_path: Path,
    database_environment: dict[str, str],
    service_name: str,
) -> None:
    run_process_group(
        [
            "pg_restore",
            "--clean",
            "--if-exists",
            "--no-owner",
            "--no-privileges",
            "--single-transaction",
            "--dbname",
            f"service={service_name}",
            str(dump_path),
        ],
        check=True,
        env=database_environment,
    )


def _restore_command(dump_path: Path, service_name: str) -> list[str]:
    return [
        "pg_restore",
        "--clean",
        "--if-exists",
        "--no-owner",
        "--no-privileges",
        "--single-transaction",
        "--dbname",
        f"service={service_name}",
        str(dump_path),
    ]


def _restore_target_with_upload_compensation(
    dump_path: Path,
    database_environment: dict[str, str],
    staged_uploads: Path,
    uploads_target: Path,
) -> None:
    with blocked_termination_signals():
        replacement = begin_directory_replacement(staged_uploads, uploads_target)
        try:
            run_process_group(
                _restore_command(dump_path, "onetree_import"),
                check=True,
                env=database_environment,
            )
        except BaseException:
            replacement.rollback()
            raise
        else:
            replacement.commit()


def _assert_required_accounts(
    database_environment: dict[str, str], service_name: str
) -> None:
    quoted_identifiers = ", ".join(
        f"'{identifier}'" for identifier, _role in REQUIRED_ACCOUNTS
    )
    accounts = _query(
        database_environment,
        service_name,
        "SELECT identifier || ':' || role FROM \"user\" "
        f"WHERE identifier IN ({quoted_identifiers}) ORDER BY identifier",
    )
    expected_accounts = [
        f"{identifier}:{role}" for identifier, role in REQUIRED_ACCOUNTS
    ]
    if accounts != expected_accounts:
        raise RuntimeError("恢复后的必须保留账号记录不一致")


def _assert_createdb_permission(database_environment: dict[str, str]) -> None:
    permission = _query(
        database_environment,
        "onetree_import",
        "SELECT CASE WHEN rolcreatedb THEN 'allowed' ELSE 'denied' END "
        "FROM pg_roles WHERE rolname = current_user",
    )
    if permission != ["allowed"]:
        raise RuntimeError("维护态数据库角色必须具备 CREATEDB 权限")


def _validate_dump_in_temporary_database(
    dump_path: Path,
    manifest: dict[str, object],
    target_database_url: str,
    staging_root: Path,
    target_database_environment: dict[str, str],
) -> None:
    validation_name = f"onetree_import_verify_{uuid.uuid4().hex}"
    validation_url = replace_database_name(target_database_url, validation_name)
    validation_environment = postgres_service_environment(
        validation_url,
        staging_root / "validation_pg_service.conf",
        "onetree_validation",
    )
    try:
        run_process_group(
            [
                "createdb",
                "--maintenance-db=service=onetree_import",
                validation_name,
            ],
            check=True,
            env=target_database_environment,
        )
        _restore_dump(dump_path, validation_environment, "onetree_validation")
        restored_identity = inspect_database_identity(
            DEPLOY_DIR.parent / "backend", validation_url
        )
        manifest_identity = {
            "schema_state": manifest["schema_state"],
            "alembic_revision": manifest["alembic_revision"],
        }
        if restored_identity != manifest_identity:
            raise RuntimeError("验证数据库 schema state 与 manifest 不一致")
        migrated_identity = migrate_database_to_head(
            DEPLOY_DIR.parent / "backend", validation_url
        )
        repository_heads = repository_revision_sets(DEPLOY_DIR.parent / "backend")[
            "heads"
        ]
        if (
            migrated_identity
            != {
                "schema_state": "versioned",
                "alembic_revision": next(iter(repository_heads), None),
            }
            or len(repository_heads) != 1
        ):
            raise RuntimeError("验证数据库未迁移到仓库唯一 Alembic head")
        _assert_required_accounts(validation_environment, "onetree_validation")
    finally:
        with blocked_termination_signals():
            run_process_group(
                [
                    "dropdb",
                    "--force",
                    "--if-exists",
                    "--maintenance-db=service=onetree_import",
                    validation_name,
                ],
                check=True,
                env=target_database_environment,
            )


def main() -> int:
    parser = argparse.ArgumentParser(description="导入 OneTree 数据迁移包")
    parser.add_argument("bundle", type=Path)
    parser.add_argument("uploads_target", type=Path)
    arguments = parser.parse_args()
    database_url = os.environ.get("TARGET_DATABASE_URL", "")
    if not database_url:
        raise RuntimeError("必须通过 TARGET_DATABASE_URL 指定维护态目标库")
    if os.environ.get("ONETREE_MAINTENANCE_MODE") != "1":
        raise RuntimeError("仅允许在 ONETREE_MAINTENANCE_MODE=1 时导入")

    raw_uploads_target = arguments.uploads_target.expanduser()
    validate_replacement_target(raw_uploads_target)
    uploads_target = raw_uploads_target.absolute()
    uploads_target.parent.mkdir(parents=True, exist_ok=True)
    validate_replacement_target(uploads_target)
    staging_root = Path(
        tempfile.mkdtemp(prefix=".migration-import.", dir=uploads_target.parent)
    )
    verified_bundle = staging_root / "bundle"
    staged_uploads = staging_root / "uploads"
    with termination_signal_guard():
        try:
            database_environment = postgres_service_environment(
                database_url, staging_root / "pg_service.conf", "onetree_import"
            )
            _assert_createdb_permission(database_environment)
            manifest = extract_verified_bundle(
                arguments.bundle.resolve(), verified_bundle
            )
            assert_manifest_repository_revision(manifest, DEPLOY_DIR.parent / "backend")
            extract_upload_archive(
                verified_bundle / "knowledge-base-uploads.tar", staged_uploads
            )
            _validate_dump_in_temporary_database(
                verified_bundle / "database.dump",
                manifest,
                database_url,
                staging_root,
                database_environment,
            )
            _restore_target_with_upload_compensation(
                verified_bundle / "database.dump",
                database_environment,
                staged_uploads,
                uploads_target,
            )
        finally:
            shutil.rmtree(staging_root, ignore_errors=True)
    print("数据库、账号和教材文件导入完成")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
